# =============================================================================
# MCP server API keys — set these in the Cloud environment's env-var config
# (Cloud env → Environment variables). bootstrap.sh reads them to register the
# custom stdio MCP servers on every fresh session.
#
# These are SECRETS. This .example file lists NAMES ONLY — never commit real
# values. Paste the real values into the environment config, not the repo.
# =============================================================================

# ---- KTU / BTU ----
CLOSEBOT_API_KEY=
COMPANYCAM_TOKEN=
SM_KEY_KTU=
SM_KEY_BTU=

# Google Ads (OAuth2 desktop client) — shared by the STDIO google-ads AND gmb
# servers. NOTE: if you use the Render-hosted google-ads instead (via
# GOOGLEADS_MCP_AUTH_TOKEN below), these four are only needed for the `gmb`
# server — the Render service already holds its own copy of the Google creds.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Render-hosted Google Ads + LSA MCP (ktubtu-mcp-google-ads) — the service's
# auto-generated MCP_AUTH_TOKEN (Render → ktubtu-mcp-google-ads → Environment).
# Registers `google-ads` (search + Local Services Ads) as a static-bearer HTTP
# MCP server for Cloud sessions / the paid agent, WITHOUT needing the Google
# OAuth creds in Cloud env (they live in Render). NOT a claude.ai connector
# (OAuth-only). This is the fast path to light up Google Ads + LSA for Paid.
GOOGLEADS_MCP_AUTH_TOKEN=

# Google Business Profile (gmb) — plus the three GOOGLE_ADS OAuth vars above
GMB_ACCOUNT_ID=
GMB_LOCATION_KTU=
GMB_LOCATION_BTU=

# HighLevel Private Integration Tokens (full value incl. the "pit-" prefix).
# bootstrap.sh registers ghl-ktu / ghl-btu against LeadConnector's hosted MCP
# endpoint (services.leadconnectorhq.com/mcp/) with the matching locationId.
GHL_PIT_KTU=
GHL_PIT_BTU=

# Microsoft Clarity Data-Export tokens (optional; ~10 calls/project/day cap)
# These drive the direct npm @microsoft/clarity-mcp-server (clarity-*-export).
CLARITY_KTU_TOKEN=
CLARITY_BTU_TOKEN=

# Render-hosted Clarity MCP (ktubtu-mcp-clarity) — the service's auto-generated
# MCP_AUTH_TOKEN (Render → ktubtu-mcp-clarity → Environment). Registers the
# hosted Data-Export wrapper (KTU+BTU) as a static-bearer HTTP MCP server so
# Cloud sessions / the paid agent can reach it. NOT usable as a claude.ai
# connector (those require OAuth; this service is static-bearer only).
CLARITY_MCP_AUTH_TOKEN=

# ---- Jatalia / Earthwise ----
SHIPSTATION_API_KEY=
AMAZON_SP_CLIENT_ID=
AMAZON_SP_CLIENT_SECRET=
AMAZON_SP_REFRESH_TOKEN=

# ---- Shared ----
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
